<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Name shown under our icon in the iMessage app drawer. -->
	<key>CFBundleDisplayName</key>
	<string>ImHim</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!-- NSExtension: declares this bundle as an iMessage app, NOT a
	     keyboard. The point identifier here is the difference between
	     "appears in iMessage's + drawer" and "appears in Settings →
	     Keyboards". This is the WingAI-style surface — when the user
	     taps the + button while composing an iMessage, our icon shows
	     up in the drawer, they tap it, our UI expands, scans the
	     latest screenshot, drops three replies into the chat. -->
	<key>NSExtension</key>
	<dict>
		<!-- Programmatic UI — no storyboard needed. The principal class
		     name is namespaced by PRODUCT_MODULE_NAME so the loader
		     finds MessagesViewController inside the ImHimMessages
		     binary. -->
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.message-payload-provider</string>
		<key>NSExtensionPrincipalClass</key>
		<string>$(PRODUCT_MODULE_NAME).MessagesViewController</string>
	</dict>

	<!-- Photo Library usage string. Read by iOS the first time we ask
	     for Photos access so we can grab the most recent screenshot. -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>ImHim reads your most recent screenshot inside Messages so it can write three reply options to drop into the chat. The screenshot isn't stored beyond that one request.</string>
</dict>
</plist>
